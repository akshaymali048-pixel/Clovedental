# Vercel Neon Postgres — use pooled URL for app, direct URL for Prisma migrations
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# After verifying your domain in Resend (resend.com/domains):
RESEND_FROM_EMAIL="Clove Dental <leads@yourclinic.com>"
SESSION_SECRET="your-32-character-secret-here-generate-with-openssl"
# Must be at least 32 characters — iron-session rejects shorter values
ADMIN_EMAIL="admin@yourclinic.com"
ADMIN_PASSWORD="change-me-before-deploy"
NEXT_PUBLIC_SITE_URL="https://yourclinic.com"
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."
